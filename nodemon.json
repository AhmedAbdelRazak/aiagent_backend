{
  "verbose": false,
  "legacyWatch": true,
  "watch": [
    "server.js",
    "controllers",
    "routes",
    "models",
    "middlewares",
    "assets",
    "utils",
    ".env",
    "package.json"
  ],
  "ext": "js,json,env",
  "ignore": [
    "node_modules/**",
    "uploads/**",
    "PhotosForLongerVideos/**",
    "*.log"
  ],
  "delay": "750",
  "env": {
    "NODE_ENV": "development"
  },
  "restartable": "rs"
}
